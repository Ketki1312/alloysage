{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/api/health", "dest": "/api/health.py" },
    { "src": "/api/model-info", "dest": "/api/model_info.py" },
    { "src": "/api/predict", "dest": "/api/predict.py" },
    { "src": "/api/predict-all-sets", "dest": "/api/predict_all_sets.py" },
    { "src": "/api/load", "dest": "/api/load_data.py" },
    { "src": "/(.*)", "dest": "/frontend/dist/$1" }
  ]
}